// Test Type System
// Comprehensive tests for the type system

import "TypeSystem.li"
import "TypeInference.li"
import "TypeChecker.li"

func test_basic_types() {
    print("=== Testing Basic Types ===")
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    let str_type: Type = Type_new(TYPE_STR(), "str")
    let bool_type: Type = Type_new(TYPE_BOOL(), "bool")
    
    print("int32: " + Type_to_string(int_type))
    print("str: " + Type_to_string(str_type))
    print("bool: " + Type_to_string(bool_type))
    
    print("int32 is numeric: " + i32_to_str(Type_is_numeric(int_type)))
    print("str is pointer: " + i32_to_str(Type_is_ptr(str_type)))
    print("bool is bool: " + i32_to_str(Type_is_bool(bool_type)))
}

func test_type_equality() {
    print("\n=== Testing Type Equality ===")
    
    let int1: Type = Type_new(TYPE_INT32(), "int32")
    let int2: Type = Type_new(TYPE_INT32(), "int32")
    let str1: Type = Type_new(TYPE_STR(), "str")
    
    print("int32 == int32: " + i32_to_str(Type_equals(int1, int2)))
    print("int32 == str: " + i32_to_str(Type_equals(int1, str1)))
}

func test_symbol_table() {
    print("\n=== Testing Symbol Table ===")
    
    let table: SymbolTable = SymbolTable_new(0)
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    SymbolTable_define(table, "x", int_type)
    SymbolTable_define(table, "y", int_type)
    
    let sym_x: Symbol = SymbolTable_lookup(table, "x")
    let sym_y: Symbol = SymbolTable_lookup(table, "y")
    let sym_z: Symbol = SymbolTable_lookup(table, "z")
    
    print("Found x: " + i32_to_str(sym_x.type.kind != TYPE_UNKNOWN()))
    print("Found y: " + i32_to_str(sym_y.type.kind != TYPE_UNKNOWN()))
    print("Found z: " + i32_to_str(sym_z.type.kind != TYPE_UNKNOWN()))
}

func test_scoped_symbol_table() {
    print("\n=== Testing Scoped Symbol Table ===")
    
    let global: SymbolTable = SymbolTable_new(0)
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    SymbolTable_define(global, "global_var", int_type)
    
    let local: SymbolTable = SymbolTable_new(global)
    SymbolTable_define(local, "local_var", int_type)
    
    let sym1: Symbol = SymbolTable_lookup(local, "local_var")
    let sym2: Symbol = SymbolTable_lookup(local, "global_var")
    let sym3: Symbol = SymbolTable_lookup(global, "local_var")
    
    print("Local finds local_var: " + i32_to_str(sym1.type.kind != TYPE_UNKNOWN()))
    print("Local finds global_var: " + i32_to_str(sym2.type.kind != TYPE_UNKNOWN()))
    print("Global finds local_var: " + i32_to_str(sym3.type.kind != TYPE_UNKNOWN()))
}

func test_type_inference() {
    print("\n=== Testing Type Inference ===")
    
    let lit_int: Type = infer_literal_type("42")
    let lit_bool: Type = infer_literal_type("true")
    let lit_str: Type = infer_literal_type("hello")
    
    print("42 inferred as: " + Type_to_string(lit_int))
    print("true inferred as: " + Type_to_string(lit_bool))
    print("hello inferred as: " + Type_to_string(lit_str))
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    let add_result: Type = infer_binary_type(int_type, int_type, "+")
    let cmp_result: Type = infer_binary_type(int_type, int_type, "<")
    
    print("int32 + int32 = " + Type_to_string(add_result))
    print("int32 < int32 = " + Type_to_string(cmp_result))
}

func test_type_compatibility() {
    print("\n=== Testing Type Compatibility ===")
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    let str_type: Type = Type_new(TYPE_STR(), "str")
    let any_type: Type = Type_new(TYPE_ANY(), "any")
    
    print("int32 compatible with int32: " + i32_to_str(types_compatible(int_type, int_type)))
    print("int32 compatible with str: " + i32_to_str(types_compatible(int_type, str_type)))
    print("any compatible with int32: " + i32_to_str(types_compatible(any_type, int_type)))
    print("any compatible with str: " + i32_to_str(types_compatible(any_type, str_type)))
}

func test_llvm_type_mapping() {
    print("\n=== Testing LLVM Type Mapping ===")
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    let str_type: Type = Type_new(TYPE_STR(), "str")
    let bool_type: Type = Type_new(TYPE_BOOL(), "bool")
    let ptr_type: Type = Type_new(TYPE_PTR(), "ptr")
    
    print("int32 -> " + Type_to_llvm(int_type))
    print("str -> " + Type_to_llvm(str_type))
    print("bool -> " + Type_to_llvm(bool_type))
    print("ptr -> " + Type_to_llvm(ptr_type))
}

func test_type_casting() {
    print("\n=== Testing Type Casting ===")
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    let ptr_type: Type = Type_new(TYPE_PTR(), "ptr")
    
    print("ptr -> int32 needs cast: " + i32_to_str(needs_cast(ptr_type, int_type)))
    print("int32 -> ptr needs cast: " + i32_to_str(needs_cast(int_type, ptr_type)))
    print("int32 -> int32 needs cast: " + i32_to_str(needs_cast(int_type, int_type)))
    
    if (needs_cast(ptr_type, int_type)) {
        let cast_instr: str = generate_cast(ptr_type, int_type, "%t1")
        print("Cast instruction: " + cast_instr)
    }
}

func test_function_signature() {
    print("\n=== Testing Function Signature ===")
    
    let ret_type: Type = Type_new(TYPE_INT32(), "int32")
    let sig: FunctionSignature = FunctionSignature_new("add", ret_type)
    
    let param1: Type = Type_new(TYPE_INT32(), "int32")
    let param2: Type = Type_new(TYPE_INT32(), "int32")
    
    FunctionSignature_add_param(sig, "a", param1)
    FunctionSignature_add_param(sig, "b", param2)
    
    print("Function: " + sig.name)
    print("Return type: " + Type_to_string(sig.return_type))
    print("Param count: " + i32_to_str(FunctionSignature_param_count(sig)))
    
    let p1_type: Type = FunctionSignature_get_param_type(sig, 0)
    let p2_type: Type = FunctionSignature_get_param_type(sig, 1)
    
    print("Param 0 type: " + Type_to_string(p1_type))
    print("Param 1 type: " + Type_to_string(p2_type))
}

func test_struct_definition() {
    print("\n=== Testing Struct Definition ===")
    
    let def: StructDefinition = StructDefinition_new("Point")
    
    let int_type: Type = Type_new(TYPE_INT32(), "int32")
    StructDefinition_add_field(def, "x", int_type)
    StructDefinition_add_field(def, "y", int_type)
    
    print("Struct: " + def.name)
    print("Field count: " + i32_to_str(ptr_array_len(def.field_names)))
    
    let x_type: Type = StructDefinition_get_field_type(def, "x")
    let y_type: Type = StructDefinition_get_field_type(def, "y")
    let z_type: Type = StructDefinition_get_field_type(def, "z")
    
    print("Field x type: " + Type_to_string(x_type))
    print("Field y type: " + Type_to_string(y_type))
    print("Field z found: " + i32_to_str(z_type.kind != TYPE_UNKNOWN()))
}

func test_advanced_type_checker() {
    print("\n=== Testing Advanced Type Checker ===")
    
    let atc: AdvancedTypeChecker = AdvancedTypeChecker_new()
    
    // Register a function
    let ret_type: Type = Type_new(TYPE_INT32(), "int32")
    let sig: FunctionSignature = FunctionSignature_new("multiply", ret_type)
    FunctionSignature_add_param(sig, "a", Type_new(TYPE_INT32(), "int32"))
    FunctionSignature_add_param(sig, "b", Type_new(TYPE_INT32(), "int32"))
    AdvancedTypeChecker_register_function(atc, sig)
    
    // Register a struct
    let def: StructDefinition = StructDefinition_new("Rectangle")
    StructDefinition_add_field(def, "width", Type_new(TYPE_INT32(), "int32"))
    StructDefinition_add_field(def, "height", Type_new(TYPE_INT32(), "int32"))
    AdvancedTypeChecker_register_struct(atc, def)
    
    // Lookup
    let found_sig: FunctionSignature = AdvancedTypeChecker_lookup_function(atc, "multiply")
    let found_def: StructDefinition = AdvancedTypeChecker_lookup_struct(atc, "Rectangle")
    
    print("Found function: " + i32_to_str(found_sig != 0))
    print("Found struct: " + i32_to_str(found_def != 0))
    
    if (found_sig != 0) {
        print("Function name: " + found_sig.name)
        print("Function params: " + i32_to_str(FunctionSignature_param_count(found_sig)))
    }
    
    if (found_def != 0) {
        print("Struct name: " + found_def.name)
        print("Struct fields: " + i32_to_str(ptr_array_len(found_def.field_names)))
    }
}

func run_all_tests() {
    print("========================================")
    print("   TinhLinh Type System Test Suite")
    print("========================================\n")
    
    test_basic_types()
    test_type_equality()
    test_symbol_table()
    test_scoped_symbol_table()
    test_type_inference()
    test_type_compatibility()
    test_llvm_type_mapping()
    test_type_casting()
    test_function_signature()
    test_struct_definition()
    test_advanced_type_checker()
    
    print("\n========================================")
    print("   All Tests Completed!")
    print("========================================")
}

run_all_tests()
