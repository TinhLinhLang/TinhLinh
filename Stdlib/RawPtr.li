}

// Alignment helpers
@unsafe export func raw_ptr_align(p: raw_ptr<int32>, alignment: int32): raw_ptr<int32> {
    let addr: int32 = raw_ptr_to_int(p)
    let remainder: int32 = addr % alignment
    if (remainder == 0) {
        return p
    }
    let offset: int32 = alignment - remainder
    return raw_ptr_add_bytes(p, offset)
}

// Check if pointer is aligned
@unsafe export func raw_ptr_is_aligned(p: raw_ptr<int32>, alignment: int32): bool {
    let addr: int32 = raw_ptr_to_int(p)
    return (addr % alignment) == 0
}
